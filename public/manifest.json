{
  "id": "/",
  "name": "WorkMate",
  "short_name": "WorkMate",
  "description": "Seu assistente pessoal",
  "start_url": "/hub",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "display_override": [
    "standalone",
    "window-controls-overlay"
  ],
  "background_color": "#212121",
  "theme_color": "#212121",
  "categories": [
    "work",
    "productivity"
  ],
  "protocol_handlers": [
    {
      "protocol": "web+workmate",
      "url": "/?url=%s"
    }
  ],
  "icons": [
    {
      "src": "/icons/android/launchericon-transparent-48x48.png",
      "sizes": "48x48",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/android/launchericon-solid-48x48.png",
      "sizes": "48x48",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/android/launchericon-transparent-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/android/launchericon-solid-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/android/launchericon-transparent-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/android/launchericon-solid-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/android/launchericon-transparent-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/android/launchericon-solid-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/android/launchericon-transparent-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/android/launchericon-solid-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/android/launchericon-transparent-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/android/launchericon-solid-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "share_target": {
    "action": "/hub/chat",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "audio",
          "accept": [
            "audio/*",
            ".opus",
            ".m4a",
            ".mp3",
            ".wav",
            ".ogg",
            ".webm",
            ".aac"
          ]
        }
      ]
    }
  }
}
